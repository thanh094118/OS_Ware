@startuml name
!theme plain
title Web Log Analysis Pipeline Architecture

start

:access.log;

:[1] Log Collector;
:raw log lines;

:[2] Parser;
:parsed dictionary;

:[3] Normalizer;
:common schema;

:[4] Request Preprocessor;
:normalized request fields;

split
    -> [5.1] Rule-based Detector;
    :rule alerts;
    -> [8] Risk Scoring & Post-processing;
    -> [9] Exporter / Report;
    stop

split again
    -> [5.2] Feature Extractor;
    :features.csv;

    -> [6] AI Binary Model;
    :normal / anomalous;

    if (Prediction == anomalous?) then (yes)
        -> [7] AI Multi-label Model;
        :web attack types;
        -> [8] Exporter / Report;
        stop
    else (no)
        :normal traffic;
        -> [8] Exporter / Report;
        stop
    endif

end split

@enduml